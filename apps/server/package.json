{
  "name": "@fullstack-template/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:studio": "bunx drizzle-kit studio"
  },
  "dependencies": {
    "@fullstack-template/schema": "file:../../packages/schema",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.22",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.3",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3"
  }
}
