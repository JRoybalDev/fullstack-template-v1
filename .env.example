# Docker maps container port 5432 to this host port by default.
POSTGRES_HOST_PORT=5433

# Used by Drizzle and the Bun API server.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/fullstack_template

# Private dashboard access code and X-Admin-Key value for protected API requests.
ADMIN_KEY=939066

# Public URL where the API is reachable during local development.
PUBLIC_API_URL=http://localhost:3001
