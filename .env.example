# -----------------------------------------------------------------------------
# Fullstack Template Environment
# -----------------------------------------------------------------------------
# Copy this file to `.env` at the project root. The root `.env` is the single
# env source for Docker Compose, Drizzle, the Bun API, and the Vite web app.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Host port used by Docker Compose. The Postgres container still listens on 5432.
POSTGRES_HOST_PORT=5433

# Used by Drizzle migrations and the Bun API server.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/fullstack_template

# -----------------------------------------------------------------------------
# Local Servers And Public URLs
# -----------------------------------------------------------------------------
# Bun/Hono API port.
PORT=3001

# Browser-facing web origin. Used by CORS and Better Auth trusted origins.
WEB_ORIGIN=http://localhost:5173

# Browser-facing API URL. Useful for generated links and deployed API references.
PUBLIC_API_URL=http://localhost:3001

# Vite dev proxy target for /api and /uploads.
VITE_API_PROXY_TARGET=http://localhost:3001

# Optional Better Auth client base URL. Leave blank for same-origin auth.
VITE_AUTH_BASE_URL=

# Comma-separated origins allowed to call the API with credentials.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Site name, favicon, page-title format, and dashboard title are code-configured
# in apps/web/src/shared/siteConfig.ts so they stay versioned with the frontend.

# -----------------------------------------------------------------------------
# Auth Preset
# -----------------------------------------------------------------------------
# admin-key: Simple projects. Dashboard/API writes use ADMIN_KEY + X-Admin-Key.
# better-auth: Larger projects. Dashboard/API writes use Better Auth sessions
# and server-side admin role authorization.
AUTH_MODE=admin-key

# Required only when AUTH_MODE=admin-key.
ADMIN_KEY=replace-with-a-long-random-secret

# -----------------------------------------------------------------------------
# Better Auth
# -----------------------------------------------------------------------------
# Required when AUTH_MODE=better-auth. Use a strong 32+ character secret.
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters

# Public URL where Better Auth is mounted. Usually the web origin in same-origin
# deployments, or the API origin if auth is hosted separately.
BETTER_AUTH_URL=http://localhost:5173

# Comma-separated origins Better Auth should trust for auth requests.
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# private: Default template mode. Admins create users from the dashboard.
# public: Allows public sign up from the dashboard gate.
BETTER_AUTH_SIGNUP_MODE=private

# Comma-separated roles allowed to access protected dashboard/API writes.
BETTER_AUTH_ADMIN_ROLES=admin

# Password reset email mode.
# console: Logs reset links in the API console for local development.
# provider: Sends reset links through Resend.
PASSWORD_RESET_EMAIL_MODE=console
PASSWORD_RESET_FROM_EMAIL=Fullstack Template <noreply@example.com>

# Required when PASSWORD_RESET_EMAIL_MODE=provider. Server-only secret.
RESEND_API_KEY=

# Optional Resend testing override. Useful before your domain is verified.
# When set, all password reset emails are sent to this address instead of users.
RESEND_AUDIENCE_OVERRIDE=

# -----------------------------------------------------------------------------
# Better Auth Bootstrap Admin
# -----------------------------------------------------------------------------
# Optional first admin seed for AUTH_MODE=better-auth.
# Set these once, start the API, sign in, then remove the email/password values.
BETTER_AUTH_BOOTSTRAP_ADMIN_EMAIL=
BETTER_AUTH_BOOTSTRAP_ADMIN_PASSWORD=
BETTER_AUTH_BOOTSTRAP_ADMIN_NAME=Template Admin

# -----------------------------------------------------------------------------
# Better Auth Cookies
# -----------------------------------------------------------------------------
# Set true in HTTPS production deployments.
AUTH_COOKIE_SECURE=false

# Enable only when auth cookies must work across trusted subdomains.
AUTH_COOKIE_CROSS_SUBDOMAIN=false

# Cookie domain for cross-subdomain auth, e.g. example.com.
# Leave blank for host-only cookies.
AUTH_COOKIE_DOMAIN=

# -----------------------------------------------------------------------------
# Rate Limits
# -----------------------------------------------------------------------------
# Better Auth route limits for sign in, signup, and password reset.
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX_REQUESTS=20

# Private admin API route limits.
ADMIN_RATE_LIMIT_WINDOW_SECONDS=60
ADMIN_RATE_LIMIT_MAX_REQUESTS=120

# Upload route limits.
UPLOAD_RATE_LIMIT_WINDOW_SECONDS=60
UPLOAD_RATE_LIMIT_MAX_REQUESTS=20

# -----------------------------------------------------------------------------
# Security Headers
# -----------------------------------------------------------------------------
# Adds CSP, frame protection, content sniffing protection, referrer policy, and
# permissions policy headers to API responses.
SECURITY_HEADERS_ENABLED=true

# Enable only on HTTPS production domains. HSTS tells browsers to force HTTPS for
# the domain and subdomains for one year.
SECURITY_HSTS_ENABLED=false

# -----------------------------------------------------------------------------
# Uploads
# -----------------------------------------------------------------------------
# local: Stores files in UPLOAD_DIR and creates local thumbnails.
# cloudinary: Uploads originals to Cloudinary and returns optimized thumbnail URLs.
# Replacing or deleting dashboard uploads removes the old stored asset when
# storage metadata is available.
STORAGE_DRIVER=local

# Local directory where the API stores uploaded originals and thumbnails.
UPLOAD_DIR=uploads

# Required when STORAGE_DRIVER=cloudinary. Cloudinary has a free tier suitable
# for small templates, demos, and early client projects.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
# Server-only secret.
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=fullstack-template
